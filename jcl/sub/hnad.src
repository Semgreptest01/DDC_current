#------------------------------------------------------------------------#
# Shell-id        : hnad
# Shell-名        : hnad.src
# 機能            : ＤＤＣ返品コスト削減
#                 : 更新共通シェル変数定義（本番用）
# 作成者          : O.Ogawara
# 作成日          : 2009/10/14
# 修正履歴        : 
# No 修正日付     修正者     修正内容
#  1 200X/XX/XX   X.XXXXXXX  XXXXXXXX
#------------------------------------------------------------------------#
alias rm 'rm -f'
#------------------------------------------------------------------------#
#       ＯＲＡＣＬＥ関係環境変数
#------------------------------------------------------------------------#
setenv PATH /usr/bin:/etc:/usr/sbin:/usr/ucb:$HOME/bin:/usr/bin/X11:/sbin:/usr/java14/bin:.
setenv ORACLE_BASE /opt/oracle
setenv ORACLE_HOME $ORACLE_BASE/product/10.2.0/db
setenv NLS_LANG Japanese_Japan.JA16SJISTILDE
setenv ORACLE_SID LEWP4A
setenv PATH $ORACLE_HOME/bin:$PATH
#------------------------------------------------------------------------#
#      環境用共通設定
#------------------------------------------------------------------------#
set PROD_DIR = "/wk_apl/apl/prod"
set RDWKDIR = "/wk_apl/apl/wk002/hnad/dat"
set BKUPDIR = "/wk_apl/apl/wk002/hnad/dat"
set IODIR   = "/wk_apl/apl/wk002/hnad/dat"
set WKDIR   = "/wk_apl/apl/wk002/hnad/dat"
#------------------------------------------------------------------------#
#      JCLディレクトリ
#------------------------------------------------------------------------#
set JCLDIR="$PROD_DIR/jcl"
#------------------------------------------------------------------------#
#      ログディレクトリ
#------------------------------------------------------------------------#
set LOG_DIR="/wk_apl/apl/wk002/hnad/log"
#------------------------------------------------------------------------#
#      モジュールディレクトリ
#------------------------------------------------------------------------#
set PGMDIR="$PROD_DIR/bin"
#------------------------------------------------------------------------#
#      Perlディレクトリ
#------------------------------------------------------------------------#
setenv PERLDIR "$PROD_DIR/perl"
#------------------------------------------------------------------------#
#      DBデータ定義ディレクトリ
#------------------------------------------------------------------------#
set CTLDIR = $PROD_DIR/ora10/ctl
set SQLDIR = $PROD_DIR/ora10
set EXPORT_DIR = $PROD_DIR/ora10/export
set IMPORT_DIR = $PROD_DIR/ora10/import
set PLSQLDIR   = $PROD_DIR/plsql
#------------------------------------------------------------------------#
#      パラメータ変数セット(ORACL)
#------------------------------------------------------------------------#
set ORAUID=$1                             # オラクル・ユーザーID
set ORAUIDL=6                             # オラクル・ユーザーID レングス
set ORAPWD=$2                             # オラクル・パスワード
set ORAPWDL=8                             # オラクル・パスワード レングス
#------------------------------------------------------------------------#
#      オラクルユーザーID・PWD環境変数設定
#------------------------------------------------------------------------#
setenv ORAUID  $ORAUID
setenv ORAUIDL $ORAUIDL
setenv ORAPWD  $ORAPWD
setenv ORAPWDL $ORAPWDL
#------------------------------------------------------------------------#
#   その他オラクル関連設定
#------------------------------------------------------------------------#
set SQL_NAME   = "sqlplus"
set DRCTL_DIR  = "$PROD_DIR/ora10/ctl"
set ORAOUT_DIR = "HNAD_DAT1"
#------------------------------------------------------------------------#
#      その他設定
#------------------------------------------------------------------------#
set FTPASSTYPE = "MB"
unalias rm
unalias cp
